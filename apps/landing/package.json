{
  "name": "@bevero-platform/landing",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "typecheck": "echo 'Vite+React does not require explicit type checking'",
    "test": "vitest run && node --test tests/*.test.mjs",
    "test:coverage": "vitest run --coverage && node --test tests/*.test.mjs",
    "test:e2e": "playwright test",
    "test:screenshot-ownership": "node --test tests/screenshot-ownership.test.mjs"
  },
  "dependencies": {
    "jspdf": "^3.0.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.56.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^14.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^4.2.0",
    "@vitest/coverage-v8": "^2.1.9",
    "jsdom": "^25.0.1",
    "vite": "^5.0.0",
    "vitest": "^2.1.9"
  }
}
