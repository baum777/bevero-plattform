{
  "name": "@bevero-platform/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "postinstall": "prisma generate",
    "dev": "tsx watch src/server.ts",
    "smoke:inventory-api": "tsx scripts/smoke-inventory-api.ts",
    "smoke:phase2-correction": "tsx scripts/smoke-phase2-correction.ts",
    "smoke:supabase": "tsx scripts/smoke/supabase-runtime-smoke.ts",
    "smoke:browser:seed": "tsx scripts/smoke/browser-smoke-seed.ts",
    "smoke:inventory-api:live-prod": "SMOKE_TARGET=live-prod NODE_ENV=production tsx scripts/smoke-inventory-api.ts",
    "secrets:scan": "gitleaks detect --config .gitleaks.toml --redact",
    "ci": "npm run typecheck && npm run test -- --run",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest",
    "prisma:validate": "prisma validate"
  },
  "dependencies": {
    "@fastify/compress": "^8.3.1",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@prisma/client": "^6.1.0",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@vitest/coverage-v8": "^4.1.8",
    "pino-pretty": "^13.1.3",
    "prisma": "^6.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^4.1.8"
  }
}
