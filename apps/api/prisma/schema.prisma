generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  schemas   = ["public", "auth"]
}

model SyncRun {
  id           String        @id @default(cuid())
  source       String
  status       SyncRunStatus
  startedAt    DateTime      @default(now())
  finishedAt   DateTime?
  errorCode    String?
  errorMessage String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  rawPayloads RawPayload[]

  @@schema("public")
}

model RawPayload {
  id          String   @id @default(cuid())
  source      String
  externalId  String?
  entityType  String?
  payloadHash String   @unique
  payloadJson Json
  syncRunId   String?
  syncRun     SyncRun? @relation(fields: [syncRunId], references: [id])
  receivedAt  DateTime @default(now())

  @@index([source, externalId])
  @@index([payloadHash])
  @@index([syncRunId])
  @@schema("public")
}

model WorkflowEvent {
  id             String    @id @default(cuid())
  type           String
  version        Int
  source         String
  externalId     String?
  idempotencyKey String    @unique
  businessDate   DateTime?
  occurredAt     DateTime
  importedAt     DateTime  @default(now())
  payloadRef     String?
  dataJson       Json
  metadataJson   Json?
  createdAt      DateTime  @default(now())

  tasks WorkflowTask[]

  @@index([type, occurredAt])
  @@index([source, externalId])
  @@index([businessDate])
  @@schema("public")
}

model WorkflowTask {
  id              String             @id @default(cuid())
  type            String
  status          WorkflowTaskStatus
  severity        String
  title           String
  description     String?
  workflowEventId String?
  workflowEvent   WorkflowEvent?     @relation(fields: [workflowEventId], references: [id])
  assignedRole    String?
  createdAt       DateTime           @default(now())
  resolvedAt      DateTime?

  @@index([workflowEventId])
  @@schema("public")
}

model InventoryItem {
  id                String           @id @default(cuid())
  organizationId    String?          @map("organization_id")
  categoryId        String?          @map("category_id")
  name              String
  sku               String?
  category          String?
  defaultUnit       String
  minStock          Float?
  targetStock       Float?           @map("target_stock")
  displayOrder      Int?             @map("display_order")
  storageLocationId String?
  storageLocation   StorageLocation? @relation(fields: [storageLocationId], references: [id])
  categoryLink      InventoryCategory? @relation(fields: [categoryId], references: [id])
  isActive          Boolean          @default(true)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  movements          InventoryMovement[]
  refillTemplateItems BarRefillTemplateItem[]
  refillRunItems      BarRefillRunItem[]
  orderItems         PurchaseOrderItem[]
  receiptItems       GoodsReceiptItem[]
  stockSnapshots     InventoryStockSnapshot[]
  correctionRequests InventoryCorrectionRequest[]
  locationConfig     LocationInventoryConfig[]

  @@index([name])
  @@index([category])
  @@index([organizationId])
  @@index([organizationId, id])
  @@index([categoryId])
  @@index([storageLocationId])
  @@schema("public")
}

model InventoryCategory {
  id             String   @id @default(cuid())
  organizationId String?  @map("organization_id")
  name           String
  displayOrder   Int      @map("display_order")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  items InventoryItem[]

  @@index([organizationId])
  @@unique([organizationId, name])
  @@unique([organizationId, displayOrder])
  @@map("inventory_categories")
  @@schema("public")
}

model BarRefillTemplateItem {
  id              String   @id @default(cuid())
  organizationId  String?  @map("organization_id")
  displayOrder    Int      @map("display_order")
  productName     String   @map("product_name")
  unit            String?
  targetQuantity  Float?   @map("target_quantity")
  inventoryItemId String?  @map("inventory_item_id")
  inventoryItem   InventoryItem? @relation(fields: [inventoryItemId], references: [id])
  isMisc          Boolean  @default(false) @map("is_misc")
  active          Boolean  @default(true)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  runItems BarRefillRunItem[]

  @@index([organizationId])
  @@index([inventoryItemId])
  @@unique([organizationId, displayOrder])
  @@map("bar_refill_template_items")
  @@schema("public")
}

model BarRefillRun {
  id           String            @id @default(cuid())
  organizationId String          @map("organization_id")
  runDateLocal DateTime          @map("run_date_local") @db.Date
  timezone     String            @default("Europe/Berlin")
  createdBy    String            @map("created_by")
  status       BarRefillRunStatus @default(open)
  createdAt    DateTime          @default(now()) @map("created_at")
  completedAt  DateTime?         @map("completed_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")

  items BarRefillRunItem[]

  @@index([organizationId, runDateLocal])
  @@map("bar_refill_runs")
  @@schema("public")
}

model BarRefillRunItem {
  id                  String                 @id @default(cuid())
  refillRunId         String                 @map("refill_run_id")
  refillRun           BarRefillRun           @relation(fields: [refillRunId], references: [id], onDelete: Cascade)
  templateItemId      String                 @map("template_item_id")
  templateItem        BarRefillTemplateItem  @relation(fields: [templateItemId], references: [id])
  inventoryItemId     String?                @map("inventory_item_id")
  inventoryItem       InventoryItem?         @relation(fields: [inventoryItemId], references: [id])
  displayOrder        Int                    @map("display_order")
  productNameSnapshot String                 @map("product_name_snapshot")
  unitSnapshot        String?                @map("unit_snapshot")
  targetQuantity      Float?                 @map("target_quantity")
  requestedQuantity   Float?                 @map("requested_quantity")
  status              BarRefillRunItemStatus @default(open)
  confirmedBy         String?                @map("confirmed_by")
  confirmedAt         DateTime?              @map("confirmed_at")
  stockMovementId     String?                @unique @map("stock_movement_id")
  stockMovement       InventoryMovement?     @relation("BarRefillRunItemStockMovement", fields: [stockMovementId], references: [id])
  movement            InventoryMovement?     @relation("BarRefillRunItemMovement")
  createdAt           DateTime               @default(now()) @map("created_at")
  updatedAt           DateTime               @updatedAt @map("updated_at")

  @@index([refillRunId])
  @@index([templateItemId])
  @@index([inventoryItemId])
  @@unique([refillRunId, displayOrder])
  @@map("bar_refill_run_items")
  @@schema("public")
}

model Supplier {
  id             String   @id @default(cuid())
  organizationId String?  @map("organization_id")
  name           String
  email          String?
  phone          String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  purchaseOrders PurchaseOrder[]

  @@index([organizationId])
  @@schema("public")
}

model StorageLocation {
  id               String          @id @default(cuid())
  organizationId   String?         @map("organization_id")
  name             String
  type             String?
  isActive         Boolean         @default(true)
  floor            Int?            @default(0)
  temperatureZone  TemperatureZone? @map("temperature_zone")
  isCountable      Boolean         @default(true)  @map("is_countable")
  isTransferPoint  Boolean         @default(false) @map("is_transfer_point")
  walkOrder        Int?            @map("walk_order")
  workspaceGroupId String?         @map("workspace_group_id")
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  workspaceGroup    WorkspaceGroup?    @relation(fields: [workspaceGroupId], references: [id], onDelete: SetNull)
  inventoryItems    InventoryItem[]
  receiptItems      GoodsReceiptItem[]
  movements         InventoryMovement[]
  outgoingTransfers InventoryMovement[] @relation("InventoryMovementFromLocation")
  incomingTransfers InventoryMovement[] @relation("InventoryMovementToLocation")
  stockSnapshots    InventoryStockSnapshot[]
  defaultTeams      Team[]            @relation("TeamDefaultLocation")
  areaLinks         Area[]            @relation("AreaStorageLocation")
  locationConfig    LocationInventoryConfig[]
  operationalNotes  OperationalNote[]
  correctionRequests InventoryCorrectionRequest[]

  @@index([organizationId])
  @@index([organizationId, id])
  @@index([workspaceGroupId])
  @@schema("public")
}

model OrganizationMember {
  id             String           @id @default(cuid())
  organizationId String
  userId         String
  role           OrganizationRole
  createdAt      DateTime         @default(now())

  @@unique([organizationId, userId])
  @@index([userId])
  @@index([organizationId])
  @@schema("public")
}

model WorkspaceMember {
  id             String        @id @default(cuid())
  workspaceId    String
  userId         String
  role           WorkspaceRole
  organizationId String
  createdAt      DateTime      @default(now())

  @@unique([workspaceId, userId])
  @@index([userId])
  @@index([organizationId])
  @@schema("public")
}

model WorkspaceGroup {
  id             String             @id @default(cuid())
  organizationId String             @map("organization_id")
  locationId     String             @map("location_id")
  name           String
  slug           String
  type           WorkspaceGroupType
  isActive       Boolean            @default(true)  @map("is_active")
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt      @map("updated_at")

  storageLocations StorageLocation[]
  members          WorkspaceGroupMember[]

  @@unique([locationId, slug])
  @@index([organizationId])
  @@index([locationId])
  @@schema("public")
}

model WorkspaceGroupMember {
  id               String          @id @default(cuid())
  workspaceGroupId String          @map("workspace_group_id")
  userId           String          @map("user_id")
  role             KitchenTeamRole
  isDefault        Boolean         @default(false) @map("is_default")
  createdAt        DateTime        @default(now()) @map("created_at")

  workspaceGroup   WorkspaceGroup @relation(fields: [workspaceGroupId], references: [id], onDelete: Cascade)

  @@unique([workspaceGroupId, userId])
  @@index([userId])
  @@index([workspaceGroupId])
  @@schema("public")
}

model PurchaseOrder {
  id          String              @id @default(cuid())
  supplierId  String?
  supplier    Supplier?           @relation(fields: [supplierId], references: [id])
  status      PurchaseOrderStatus @default(draft)
  createdById String
  orderedAt   DateTime?
  note        String?
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  items     PurchaseOrderItem[]
  receipts  GoodsReceipt[]
  movements InventoryMovement[]

  @@index([status])
  @@index([createdAt])
  @@index([supplierId])
  @@schema("public")
}

model PurchaseOrderItem {
  id              String        @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id])
  orderedQty      Float
  receivedQty     Float         @default(0)
  unit            String
  note            String?

  @@index([purchaseOrderId])
  @@index([inventoryItemId])
  @@schema("public")
}

model GoodsReceipt {
  id              String         @id @default(cuid())
  purchaseOrderId String?
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id])
  receivedById    String
  receivedAt      DateTime       @default(now())
  note            String?
  createdAt       DateTime       @default(now())

  items     GoodsReceiptItem[]
  movements InventoryMovement[]

  @@index([purchaseOrderId])
  @@index([receivedAt])
  @@schema("public")
}

model GoodsReceiptItem {
  id                String           @id @default(cuid())
  goodsReceiptId    String
  goodsReceipt      GoodsReceipt     @relation(fields: [goodsReceiptId], references: [id], onDelete: Cascade)
  inventoryItemId   String
  inventoryItem     InventoryItem    @relation(fields: [inventoryItemId], references: [id])
  quantity          Float
  unit              String
  storageLocationId String?
  storageLocation   StorageLocation? @relation(fields: [storageLocationId], references: [id])
  note              String?

  @@index([goodsReceiptId])
  @@index([inventoryItemId])
  @@index([storageLocationId])
  @@schema("public")
}

model InventoryMovement {
  id                String                @id @default(cuid())
  idempotencyKey    String                @unique
  organizationId    String?
  inventoryItemId   String
  inventoryItem     InventoryItem         @relation(fields: [inventoryItemId], references: [id])
  type              InventoryMovementType
  quantity          Float
  unit              String
  actorUserId       String
  storageLocationId String?
  storageLocation   StorageLocation?      @relation(fields: [storageLocationId], references: [id])
  fromStorageLocationId String?            @map("from_storage_location_id")
  fromStorageLocation   StorageLocation?  @relation("InventoryMovementFromLocation", fields: [fromStorageLocationId], references: [id])
  toStorageLocationId String?              @map("to_storage_location_id")
  toStorageLocation   StorageLocation?    @relation("InventoryMovementToLocation", fields: [toStorageLocationId], references: [id])
  purchaseOrderId   String?
  purchaseOrder     PurchaseOrder?        @relation(fields: [purchaseOrderId], references: [id])
  goodsReceiptId    String?
  goodsReceipt      GoodsReceipt?         @relation(fields: [goodsReceiptId], references: [id])
  barRefillRunItemId String?              @unique @map("bar_refill_run_item_id")
  barRefillRunItem  BarRefillRunItem?     @relation("BarRefillRunItemMovement", fields: [barRefillRunItemId], references: [id])
  refillRunItemStockRef BarRefillRunItem? @relation("BarRefillRunItemStockMovement")
  procurementOrderItemId String?          @map("procurement_order_item_id")
  procurementOrderItem   ProcurementOrderItem? @relation(fields: [procurementOrderItemId], references: [id])
  relatedMovementId String?
  note              String?
  createdAt         DateTime              @default(now())

  @@index([inventoryItemId, createdAt])
  @@index([organizationId, type, createdAt])
  @@index([type])
  @@index([actorUserId])
  @@index([storageLocationId])
  @@index([fromStorageLocationId])
  @@index([toStorageLocationId])
  @@index([purchaseOrderId])
  @@index([goodsReceiptId])
  @@index([barRefillRunItemId])
  @@index([procurementOrderItemId])
  @@schema("public")
}

model InventoryStockSnapshot {
  id                String           @id @default(cuid())
  inventoryItemId   String
  inventoryItem     InventoryItem    @relation(fields: [inventoryItemId], references: [id])
  storageLocationId String?
  storageLocation   StorageLocation? @relation(fields: [storageLocationId], references: [id])
  quantity          Float
  unit              String
  calculatedAt      DateTime         @default(now())

  @@unique([inventoryItemId, storageLocationId])
  @@index([storageLocationId])
  @@index([calculatedAt])
  @@schema("public")
}

model InventoryCorrectionRequest {
  id                String                    @id @default(cuid())
  organizationId    String?                   @map("organization_id")
  inventoryItemId   String
  inventoryItem     InventoryItem             @relation(fields: [inventoryItemId], references: [id])
  storageLocationId String?                   @map("storage_location_id")
  storageLocation   StorageLocation?          @relation(fields: [storageLocationId], references: [id])
  requestedById     String
  status            InventoryCorrectionStatus @default(open)
  expectedDelta     Float
  unit              String
  reason            String
  note              String?
  expectedQuantity  Float?                    @map("expected_quantity")
  countedQuantity   Float?                    @map("counted_quantity")
  sourceLabel       String?                   @map("source_label")
  submittedAt       DateTime?                 @map("submitted_at")
  relatedMovementId String?
  reviewedById      String?
  reviewedAt        DateTime?
  createdAt         DateTime                  @default(now())

  @@index([status])
  @@index([inventoryItemId])
  @@index([organizationId, status, createdAt])
  @@index([storageLocationId])
  @@index([createdAt])
  @@schema("public")
}

model AuthUser {
  id String @id @db.Uuid

  userProfile UserProfile? @relation("AuthUserProfile")

  @@map("users")
  @@schema("auth")
}

model Team {
  id                 String   @id
  name               String
  slug               String   @unique(map: "Team_slug_key")
  defaultLocationId  String?
  createdByProfileId String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime

  defaultLocation StorageLocation? @relation("TeamDefaultLocation", fields: [defaultLocationId], references: [id], map: "Team_defaultLocationId_fkey")
  invites         TeamInvite[]
  members         TeamMember[]
  defaultProfiles UserProfile[]    @relation("UserProfileDefaultTeam")

  @@index([slug], map: "Team_slug_idx")
  @@index([defaultLocationId], map: "Team_defaultLocationId_idx")
  @@index([createdByProfileId], map: "Team_createdByProfileId_idx")
  @@schema("public")
}

model TeamInvite {
  id                 String           @id
  teamId             String
  email              String
  role               TeamRole
  tokenHash          String           @unique(map: "TeamInvite_tokenHash_key")
  status             TeamMemberStatus @default(invited)
  invitedByProfileId String
  expiresAt          DateTime
  acceptedAt         DateTime?
  revokedAt          DateTime?
  createdAt          DateTime         @default(now())

  team             Team        @relation(fields: [teamId], references: [id], onDelete: Cascade, map: "TeamInvite_teamId_fkey")
  invitedByProfile UserProfile @relation("UserProfileSentInvites", fields: [invitedByProfileId], references: [id], map: "TeamInvite_invitedByProfileId_fkey")

  @@index([teamId], map: "TeamInvite_teamId_idx")
  @@index([email], map: "TeamInvite_email_idx")
  @@index([status, expiresAt], map: "TeamInvite_status_expiresAt_idx")
  @@schema("public")
}

model TeamMember {
  id        String           @id
  teamId    String
  profileId String
  role      TeamRole
  status    TeamMemberStatus @default(active)
  createdAt DateTime         @default(now())
  updatedAt DateTime

  team    Team        @relation(fields: [teamId], references: [id], onDelete: Cascade, map: "TeamMember_teamId_fkey")
  profile UserProfile @relation("UserProfileMemberships", fields: [profileId], references: [id], onDelete: Cascade, map: "TeamMember_profileId_fkey")

  @@unique([teamId, profileId], map: "TeamMember_teamId_profileId_key")
  @@index([profileId], map: "TeamMember_profileId_idx")
  @@index([teamId, role], map: "TeamMember_teamId_role_idx")
  @@index([teamId, status], map: "TeamMember_teamId_status_idx")
  @@schema("public")
}

model UserProfile {
  id                         String   @id
  authUserId                 String   @unique(map: "UserProfile_authUserId_key") @db.Uuid
  email                      String   @unique(map: "UserProfile_email_key")
  displayName                String?
  avatarUrl                  String?
  defaultTeamId              String?
  preferredStorageLocationId String?
  preferencesJson            Json?
  isActive                   Boolean  @default(true)
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime

  authUser        AuthUser     @relation("AuthUserProfile", fields: [authUserId], references: [id], onDelete: Cascade, map: "UserProfile_authUserId_fkey")
  defaultTeam     Team?        @relation("UserProfileDefaultTeam", fields: [defaultTeamId], references: [id], map: "UserProfile_defaultTeamId_fkey")
  sentInvites     TeamInvite[] @relation("UserProfileSentInvites")
  teamMemberships TeamMember[] @relation("UserProfileMemberships")

  // Shift planning (ADR Phase 1)
  shiftAssignments   ShiftAssignment[] @relation("ShiftAssignmentUser")
  shiftSessions      ShiftSession[]    @relation("ShiftSessionUser")
  startedShiftSessions ShiftSession[]  @relation("ShiftSessionStartedBy")
  endedShiftSessions ShiftSession[]    @relation("ShiftSessionEndedBy")
  shiftSessionEvents ShiftSessionEvent[] @relation("ShiftSessionEventActor")
  taskInstances      TaskInstance[]    @relation("TaskInstanceUser")
  completedTasks     TaskInstance[]    @relation("TaskInstanceCompletedBy")
  verifiedTasks      TaskInstance[]    @relation("TaskInstanceVerifiedBy")
  reportedTaskIssues TaskIssue[]       @relation("TaskIssueReportedBy")
  resolvedTaskIssues TaskIssue[]       @relation("TaskIssueResolvedBy")
  taskComments       TaskComment[]     @relation("TaskCommentCreatedBy")
  shiftSignoffs      ShiftSignoff[]    @relation("ShiftSignoffSignedBy")

  @@index([defaultTeamId], map: "UserProfile_defaultTeamId_idx")
  @@index([preferredStorageLocationId], map: "UserProfile_preferredStorageLocationId_idx")
  @@schema("public")
}

model ProcurementMailImport {
  id               String   @id @default(cuid())
  organizationId   String   @map("organization_id")
  messageId        String   @unique @map("message_id")
  internetMessageId String? @unique @map("internet_message_id")
  mailbox          String?
  folder           String?
  from             String
  subject          String
  receivedAt       DateTime @map("received_at")
  dkimPass         Boolean  @default(false) @map("dkim_pass")
  dkimSignature    String?  @map("dkim_signature")
  parseStatus      String   @map("parse_status")
  parseConfidence  Decimal  @default(0) @map("parse_confidence") @db.Decimal(3, 2)
  rawText          String?  @map("raw_text")
  rawHtml          String?  @map("raw_html")
  graphMessageId   String?  @unique @map("graph_message_id")
  objectStorageUrl String?  @map("object_storage_url")
  parseErrorMsg    String?  @map("parse_error_msg")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  order ProcurementOrder?

  @@index([organizationId, parseStatus, receivedAt])
  @@index([messageId])
  @@index([internetMessageId])
  @@index([graphMessageId])
  @@map("procurement_mail_imports")
  @@schema("public")
}

model ProcurementOrder {
  id                  String    @id @default(cuid())
  organizationId      String    @map("organization_id")
  locationId          String?   @map("location_id")
  source              String
  sourceMailImportId  String?   @unique @map("source_mail_import_id")
  externalOrderNumber String    @map("external_order_number")
  supplierName        String    @map("supplier_name")
  orderedAt           DateTime  @map("ordered_at")
  expectedDeliveryAt  DateTime? @map("expected_delivery_at")
  status              String
  rawSnapshot         Json?     @map("raw_snapshot")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  sourceMailImport ProcurementMailImport? @relation(fields: [sourceMailImportId], references: [id])
  items            ProcurementOrderItem[]

  @@unique([organizationId, externalOrderNumber])
  @@index([organizationId, status, expectedDeliveryAt])
  @@map("procurement_orders")
  @@schema("public")
}

model ProcurementOrderItem {
  id              String   @id @default(cuid())
  orderId         String   @map("order_id")
  order           ProcurementOrder @relation(fields: [orderId], references: [id], onDelete: Cascade)
  lineNumber      Int      @map("line_number")
  productNameRaw  String   @map("product_name_raw")
  supplierSku     String?  @map("supplier_sku")
  unit            String
  orderedQty      Decimal  @map("ordered_qty") @db.Decimal(10, 3)
  deliveredQty    Decimal? @map("delivered_qty") @db.Decimal(10, 3)
  acceptedQty     Decimal? @map("accepted_qty") @db.Decimal(10, 3)
  unitPrice       Decimal? @map("unit_price") @db.Decimal(12, 4)
  taxRate         Decimal? @map("tax_rate") @db.Decimal(5, 2)
  inventoryItemId String?  @map("inventory_item_id")
  mappingStatus   String   @map("mapping_status")
  rejectionReason String?  @map("rejection_reason")
  comment         String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  movements InventoryMovement[]

  @@index([orderId])
  @@map("procurement_order_items")
  @@schema("public")
}

model ArticleMapping {
  id              String   @id @default(cuid())
  organizationId  String   @map("organization_id")
  supplierName    String   @map("supplier_name")
  productNameRaw  String   @map("product_name_raw")
  supplierSku     String?  @map("supplier_sku")
  inventoryItemId String   @map("inventory_item_id")
  createdBy       String?  @map("created_by")
  createdAt       DateTime @default(now()) @map("created_at")

  @@unique([organizationId, supplierName, productNameRaw])
  @@index([organizationId, supplierName, productNameRaw])
  @@map("article_mappings")
  @@schema("public")
}

model AutomationRule {
  id             String                      @id @default(cuid())
  organizationId String
  version        Int                         @default(1)
  enabled        Boolean                     @default(true)
  ruleType       AutomationRuleType
  name           String
  description    String?
  condition      Json
  action         Json
  evaluateOn     AutomationRuleEvaluationMode
  schedule       String?
  metadata       Json?
  createdBy      String?
  createdAt      DateTime                    @default(now())
  updatedAt      DateTime                    @updatedAt
  deletedAt      DateTime?

  suggestions AutomationSuggestion[]

  @@index([organizationId, enabled, evaluateOn])
  @@index([organizationId, ruleType])
  @@index([enabled, schedule])
  @@schema("public")
}

model AutomationSuggestion {
  id                        String                     @id @default(cuid())
  organizationId            String
  workspaceId               String?
  storageLocationId         String?
  ruleId                    String
  ruleVersion               Int
  status                    AutomationSuggestionStatus
  type                      AutomationSuggestionType
  severity                  AutomationSuggestionSeverity @default(warning)
  title                     String
