// ADR-0029-B: CUBE Source-Conflict-Validator substrate (Slice 2 of ADR-0036).
// Read-only slice; mutation surface deferred to ADR-0029-B.2. Three new
// substrates in the public schema: CUBE_Source (versioned source register),
// CUBE_SourceField (key/value claims per source), CUBE_Conflict (detected
// conflicts awaiting manager resolution). Profile-Discriminator per
// ADR-0030 §Decisions §1 does not apply here — sources are brand-übergreifend,
// org-scoped only (no locationId, no name-match downstream). PII-mitigation
// is a service-layer regex (sanitizePII) plus a DB-level CHECK (length <= 500)
// defense-in-depth backstop.

// Note: lowercase-by-design; new enum. See ADR-0029-B §16.
enum CUBE_SourceFieldConfidence {
  confirmed
  conflict_detected
  requires_manager_confirmation

  @@schema("public")
}

model CUBE_Source {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  displayName    String
  version        Int      @default(1)
  retrievedAt    DateTime
  url            String?
  payloadHash    String?
  isActive       Boolean  @default(true)
  enteredBy      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  fields CUBE_SourceField[]

  @@unique([organizationId, name, version])
  @@index([organizationId, isActive])
  @@index([organizationId, name])
  @@schema("public")
}

model CUBE_SourceField {
  id             String                     @id @default(cuid())
  organizationId String
  sourceId       String
  source         CUBE_Source                @relation(fields: [sourceId], references: [id], onDelete: Cascade)
  fieldKey       String
  fieldValue     String
  confidence     CUBE_SourceFieldConfidence @default(requires_manager_confirmation)
  discoveredAt   DateTime                   @default(now())
  updatedAt      DateTime                   @updatedAt

  @@unique([sourceId, fieldKey])
  @@index([organizationId, fieldKey])
  @@index([organizationId])
  @@index([confidence])
  @@schema("public")
}

model CUBE_Conflict {
  id                     String    @id @default(cuid())
  organizationId         String
  fieldKey               String
  sourceIds              String[]  @default([])
  detectedAt             DateTime  @default(now())
  resolvedAt             DateTime?
  resolvedBySuggestionId String?
  winningFieldValue      String?

  @@index([organizationId, resolvedAt])
  @@index([organizationId, fieldKey, resolvedAt])
  @@schema("public")
}

// ============================================================================
// ADR-0029-C: CUBE Event-Economic-Rules (Slice 3)
// ============================================================================
// 4 read-only public-schema tables for CUBE event-economics:
//   - ExclusiveRentalPolicy  (Exklusivanmietung: Miete + Mindestverzehr)
//   - AfterMidnightStaffRate (Personal-Stundensätze ab 24:00 Uhr)
//   - NonFoodComponent        (Non-Food-Komponenten, inkludiert/optional/cost-driver)
//   - FurniturePolicy         (Möbel-Schwellenwerte; Website vs. Bankettmappe)
//
// All 4 tables are append-only at the DB layer (8 BEFORE UPDATE/DELETE
// triggers, mirrors the CUBE_Conflict pattern at ADR-0029-B §11).
// All monetary fields use the *NetCents suffix (ADR-0029-C §5 binding).
// The seed inserts all rows with isActive: false + requiresManagerConfirmation: true
// (verbatim from 00c §1-§4; manager verification required before activation).
//
// See docs/DECISIONS.md ADR-0029-C and docs/tasks/logik/00c-cube-event-economic-rules.md.

