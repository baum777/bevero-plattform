enum CateringMode {
  INHOUSE
  EXTERNAL_EVENT_CATERING
  HYBRID

  @@schema("public")
}

model Organization {
  id                   String   @id @default(cuid())
  name                 String
  slug                 String   @unique
  headquartersAddress  String?
  headquartersPhone    String?
  headquartersEmail    String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  businessUnits        BusinessUnit[]
  eventConcepts        EventConcept[]
  externalCatalogEntries ExternalCatalogEntry[]
  inquiries            Inquiry[]
  routingRules         InquiryRoutingRule[]

  @@schema("public")
}

model BusinessUnit {
  id                    String           @id @default(cuid())
  organizationId        String
  organization          Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name                  BusinessUnitName
  slug                  String
  description           String?
  defaultWorkflowKey    String
  requiredInquiryFields Json?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt

  locationLinks         BusinessUnitLocation[]
  conceptLinks          BusinessUnitEventConcept[]

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@schema("public")
}

model BusinessUnitLocation {
  businessUnitId String
  businessUnit   BusinessUnit @relation(fields: [businessUnitId], references: [id], onDelete: Cascade)
  locationId     String
  isPrimary      Boolean      @default(false)
  metadata       Json?

  @@id([businessUnitId, locationId])
  @@schema("public")
}

model BusinessUnitEventConcept {
  businessUnitId  String
  businessUnit    BusinessUnit @relation(fields: [businessUnitId], references: [id], onDelete: Cascade)
  eventConceptId  String
  eventConcept    EventConcept @relation(fields: [eventConceptId], references: [id], onDelete: Cascade)

  @@id([businessUnitId, eventConceptId])
  @@schema("public")
}

model EventConcept {
  id             String           @id @default(cuid())
  organizationId String
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           EventConceptName
  customName     String?
  description    String?
  themeTags      String[]
  isActive       Boolean          @default(true)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  businessUnitLinks   BusinessUnitEventConcept[]
  locationCompatibility EventConceptLocationCompatibility[]

  @@index([organizationId])
  @@schema("public")
}

model EventConceptLocationCompatibility {
  id                       String        @id @default(cuid())
  eventConceptId           String
  eventConcept             EventConcept  @relation(fields: [eventConceptId], references: [id], onDelete: Cascade)
  locationId               String?
  externalCatalogEntryId   String?
  compatibilityScore       Int?
  notes                    String?

  @@index([eventConceptId])
  @@schema("public")
}

model ExternalCatalogEntry {
  id             String                   @id @default(cuid())
  organizationId String
  organization   Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  name           String
  slug           String
  city           String
  region         String
  type           ExternalCatalogEntryType
  capacityMin    Int?
  capacityMax    Int?
  cateringMode   CateringMode
  logisticsProfile Json?
  isActive       Boolean                  @default(true)
  metadata       Json?
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt

  @@unique([organizationId, slug])
  @@index([organizationId])
  @@schema("public")
}

model Inquiry {
  id                            String           @id @default(cuid())
  organizationId                String
  organization                  Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  businessUnitHint              BusinessUnitName?
  source                        InquirySource
  externalRef                   String?
  subject                       InquirySubject
  guestCount                    Int?
  contactName                   String
  contactEmail                  String
  contactPhone                  String?
  contactAddress                String?
  rawMessage                    String?
  preferredDate                 DateTime?
  preferredLocationId           String?
  preferredExternalCatalogEntryId String?
  status                        InquiryStatus    @default(NEW)
  assignedToUserId              String?
  routingRuleId                 String?
  createdAt                     DateTime         @default(now())
  updatedAt                     DateTime         @updatedAt

  classificationAudits InquiryClassificationAudit[]

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, businessUnitHint])
  @@index([assignedToUserId])
  @@schema("public")
}

model InquiryRoutingRule {
  id               String           @id @default(cuid())
  organizationId   String
  organization     Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  businessUnitHint BusinessUnitName
  priority         Int
  matchKeywords    String[]
  matchSubjectTypes InquirySubject[]
  matchGuestCountMin Int?
  matchGuestCountMax Int?
  isActive         Boolean          @default(true)
  description      String?
  createdByUserId  String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  @@index([organizationId, isActive, priority])
  @@schema("public")
}

model InquiryClassificationAudit {
  id               String           @id @default(cuid())
  inquiryId        String?
  inquiry          Inquiry?         @relation(fields: [inquiryId], references: [id], onDelete: SetNull)
  matchedRuleId    String?
  matchedKeywords  String[]
  confidence       Int
  businessUnitHint BusinessUnitName?
  callerUserId     String?
  createdAt        DateTime         @default(now())

  @@index([inquiryId])
  @@schema("public")
}

model EventInquiry {
  id                              String               @id @default(cuid())
  organizationId                  String
  operationalUnitId               String
  operationalUnit                 OperationalUnit      @relation(fields: [operationalUnitId], references: [id], onDelete: Cascade)
  source                          String
  subject                         EventInquirySubject
  guestCount                      Int
  contactName                     String
  contactEmail                    String
  contactPhone                    String?
  rawMessage                      String?
  preferredDate                   DateTime?
  preferredAreas                  String[]
  status                          EventInquiryStatus  @default(NEW)
  assignedToUserId                String?
  confirmationEmailSentAt         DateTime?
  confirmationExpectedWithinMinutes Int               @default(10)
  confirmationReminderSentAt      DateTime?
  createdAt                       DateTime            @default(now())
  updatedAt                       DateTime            @updatedAt

  packageSelections EventPackageSelection[]

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([operationalUnitId])
  @@index([assignedToUserId])
  @@schema("public")
}

model BeveragePackage {
  id                  String              @id @default(cuid())
  organizationId      String
  name                BeveragePackageName
  durationHours       Float
  durationHoursMin    Float
  durationHoursMax    Float
  includedCategories  String[]
  pricePerPersonCents Int?
  serviceIncluded     Boolean             @default(true)
  isActive            Boolean             @default(true)
  isKidsPackage       Boolean             @default(false)
  childAgeMin         Int?
  childAgeMax         Int?
  under5Free          Boolean             @default(false)
  eventPhaseFactor    Float               @default(1.0)
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  eventPackageBeverages EventPackageBeverage[]

  @@index([organizationId])
  @@index([organizationId, isActive])
  @@schema("public")
}

model EventPackage {
  id                   String               @id @default(cuid())
  organizationId       String
  operationalUnitId    String
  operationalUnit      OperationalUnit      @relation(fields: [operationalUnitId], references: [id], onDelete: Cascade)
  name                 String
  courseCount          Int?
  pricePerPersonCents  Int?
  priceMode            String               @default("net_excluding_vat")
  scope                String               @default("corporate_event")
  orderMode            EventPackageOrderMode @default(group_menu_required)
  requiredLeadTimeDays Int                  @default(3)
  paymentMode          String               @default("prepayment")
  cancellationPolicy   String               @default("free_until_3_days_before")
  windowSeat           String               @default("only_by_availability")
  includedItems        String[]
  addOns               String[]
  defaultGuestCount    Int                  @default(2)
  validFrom            DateTime?
  validUntil           DateTime?
  isActive             Boolean              @default(true)
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  menuItems        EventPackageMenuItem[]
  beverages        EventPackageBeverage[]
  packageSelections EventPackageSelection[]

  @@index([organizationId])
  @@index([operationalUnitId])
  @@index([operationalUnitId, isActive])
  @@schema("public")
}

model EventPackageMenuItem {
  id             String       @id @default(cuid())
  organizationId String
  eventPackageId String
  eventPackage   EventPackage @relation(fields: [eventPackageId], references: [id], onDelete: Cascade)
  menuItemId     String
  isOptional     Boolean      @default(false)
  position       Int          @default(0)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([organizationId])
  @@index([eventPackageId])
  @@schema("public")
}

model EventPackageBeverage {
  id               String          @id @default(cuid())
  organizationId   String
  eventPackageId   String
  eventPackage     EventPackage    @relation(fields: [eventPackageId], references: [id], onDelete: Cascade)
  beveragePackageId String
  beveragePackage  BeveragePackage @relation(fields: [beveragePackageId], references: [id], onDelete: Cascade)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  @@index([organizationId])
  @@index([eventPackageId])
  @@schema("public")
}

model EventPackageSelection {
  id              String       @id @default(cuid())
  organizationId  String
  eventInquiryId  String
  eventInquiry    EventInquiry @relation(fields: [eventInquiryId], references: [id], onDelete: Cascade)
  eventPackageId  String
  eventPackage    EventPackage @relation(fields: [eventPackageId], references: [id], onDelete: Cascade)
  guestCountOverride Int?
  notes           String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([organizationId])
  @@index([eventInquiryId])
  @@schema("public")
}

// ── Scope D: Operational Notes ───────────────────────────────────────────────

model OperationalNote {
  id                  String                    @id @default(cuid())
  organizationId      String
  workspaceId         String?
  storageLocationId   String?
  authorUserId        String
  authorRole          OrganizationRole
  title               String?
  body                String
  visibility          OperationalNoteVisibility @default(team)
  noteType            OperationalNoteType       @default(general)
  relatedEntityType   OperationalNoteEntityType?
  relatedEntityId     String?
  priority            OperationalNotePriority   @default(normal)
  status              OperationalNoteStatus     @default(open)
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt
  resolvedAt          DateTime?
  resolvedByUserId    String?

  storageLocation StorageLocation? @relation(fields: [storageLocationId], references: [id], onDelete: SetNull)
  auditEvents     OperationalNoteAuditEvent[]

  @@index([organizationId, status, createdAt(sort: Desc)])
  @@index([organizationId, priority, status])
  @@index([organizationId, workspaceId, status])
  @@index([organizationId, storageLocationId])
  @@index([relatedEntityType, relatedEntityId])
  @@index([authorUserId])
  @@schema("public")
}

model OperationalNoteAuditEvent {
  id          String                    @id @default(cuid())
  noteId      String
  action      OperationalNoteAuditAction
  actorUserId String
  before      Json?
  after       Json?
  createdAt   DateTime                  @default(now())

  note OperationalNote @relation(fields: [noteId], references: [id], onDelete: Cascade)

  @@index([noteId, createdAt(sort: Desc)])
  @@index([actorUserId])
  @@schema("public")
}

enum OperationalNoteVisibility {
  private
  team
  manager_only

  @@schema("public")
}

enum OperationalNoteType {
  general
  stock_issue
  delivery_issue
  handover
  maintenance
  incident
  refill_context

  @@schema("public")
}

enum OperationalNoteEntityType {
  inventory_item
  movement
  bar_refill_run
  review_task
  shift_handover
  storage_location

  @@schema("public")
}

enum OperationalNotePriority {
  normal
  important
  critical

  @@schema("public")
}

enum OperationalNoteStatus {
  open
  resolved
  archived

  @@schema("public")
}

enum OperationalNoteAuditAction {
  created
  updated
  resolved
  archived
  linked

  @@schema("public")
}

// ── Shift planning (Phase 1) ──────────────────────────────────────────────────
// Schichtplan-Import → tagesbezogene Bereichszuweisung → Aufgabenmatrix → Tagesaufgaben.
// Gardemanger/Entremetier/Saucier sind operative Tagesrollen (kitchen_areas),
// keine permanenten System-Rollen.

model KitchenArea {
  id               String   @id @default(cuid())
  organizationId   String
  workspaceGroupId String?
  slug             String
  name             String
  description      String?
  active           Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  shiftAssignments ShiftAssignment[]
  shiftSessions    ShiftSession[]
  checklistTasks   ChecklistTask[]
  taskDayMatrices  TaskDayMatrix[]
  taskInstances    TaskInstance[]

  @@unique([organizationId, slug])
  @@index([organizationId, workspaceGroupId])
  @@map("kitchen_areas")
  @@schema("public")
}

model ShiftPlanImport {
  id                  String    @id @default(cuid())
  organizationId      String
  workspaceGroupId    String?
  fileName            String
  fileSize            Int
  weekNumber          Int?
  yearNumber          Int?
  uploadedByUserId    String
  status              String
  parseErrors         Json?
  importedRowCount    Int       @default(0)
  matchedUserCount    Int       @default(0)
  unmatchedUserNames  Json?
  areaDetectionIssues Json?
  parsedData          Json?
  confirmedAt         DateTime?
  confirmedByUserId   String?
  releasedAt          DateTime?
  releasedByUserId    String?
  failureReason       String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  shiftAssignments ShiftAssignment[]
  taskInstances    TaskInstance[]

  @@index([organizationId, status, createdAt])
  @@map("shift_plan_imports")
  @@schema("public")
}

model ShiftAssignment {
  id               String          @id @default(cuid())
  organizationId   String
  importId         String
  import           ShiftPlanImport @relation(fields: [importId], references: [id], onDelete: Cascade)
  date             DateTime        @db.Date
  weekday          Int
  userId           String
  userProfile      UserProfile     @relation("ShiftAssignmentUser", fields: [userId], references: [id], onDelete: Cascade)
  workspaceGroupId String?
  areaId           String
  area             KitchenArea     @relation(fields: [areaId], references: [id])
  shiftStartAt     DateTime
  shiftEndAt       DateTime
  locationId       String?
  department       String
  assignmentType   String          @default("primary")
  sourceRow        Int?
  status           String          @default("active")
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  taskInstances TaskInstance[]
  shiftSession ShiftSession?

  @@unique([date, userId, areaId, shiftStartAt, shiftEndAt])
  @@index([organizationId, date, areaId])
  @@index([userId, date])
  @@map("shift_assignments")
  @@schema("public")
}

model ShiftSession {
  id                String   @id @default(cuid())
  organizationId    String
  workspaceGroupId  String?
  shiftAssignmentId String   @unique
  shiftAssignment   ShiftAssignment @relation(fields: [shiftAssignmentId], references: [id], onDelete: Cascade)
  userId            String
  user              UserProfile @relation("ShiftSessionUser", fields: [userId], references: [id], onDelete: Cascade)
  areaId            String
  area              KitchenArea @relation(fields: [areaId], references: [id])
  plannedStartAt    DateTime
  plannedEndAt      DateTime
  clientStartedAt   DateTime?
  serverStartedAt   DateTime?
  actualStartedAt   DateTime?
  actualEndedAt     DateTime?
  sessionStatus     String   @default("scheduled")
  startStatus       String?
  endStatus         String?
  startDeltaMinutes Int?
  endDeltaMinutes   Int?
  startedByUserId   String?
  startedBy         UserProfile? @relation("ShiftSessionStartedBy", fields: [startedByUserId], references: [id], onDelete: SetNull)
  endedByUserId     String?
  endedBy           UserProfile? @relation("ShiftSessionEndedBy", fields: [endedByUserId], references: [id], onDelete: SetNull)
  timezone          String?
  clockSkewMs       Int?
  startSource       String?
  endSource         String?
  startNote         String?
  endNote           String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  events ShiftSessionEvent[]

  @@index([organizationId, userId, plannedStartAt])
  @@index([organizationId, workspaceGroupId, plannedStartAt])
  @@map("shift_sessions")
  @@schema("public")
}

model ShiftSessionEvent {
  id              String   @id @default(cuid())
  organizationId  String
  shiftSessionId  String
  shiftSession    ShiftSession @relation(fields: [shiftSessionId], references: [id], onDelete: Cascade)
  actorUserId     String
  actor           UserProfile @relation("ShiftSessionEventActor", fields: [actorUserId], references: [id], onDelete: Restrict)
  eventType       String
  occurredAt      DateTime
  serverCreatedAt DateTime @default(now())
  payload         Json?

  @@index([organizationId, occurredAt])
  @@index([shiftSessionId, occurredAt])
  @@map("shift_session_events")
  @@schema("public")
}

model ChecklistTask {
  id                String      @id @default(cuid())
  organizationId    String
  workspaceGroupId  String?
  department        String
  areaId            String
  area              KitchenArea @relation(fields: [areaId], references: [id], onDelete: Cascade)
  title             String
  description       String?
  notes             String?
  requiresPhoto     Boolean     @default(false)
  requiresComment   Boolean     @default(false)
  requiresSignature Boolean     @default(false)
  frequency         String      @default("daily")
  sortOrder         Int         @default(0)
  active            Boolean     @default(true)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  taskDayMatrices TaskDayMatrix[]
  taskInstances   TaskInstance[]

  @@index([organizationId, department, areaId])
  @@index([active])
  @@map("checklist_tasks")
  @@schema("public")
}

model TaskDayMatrix {
  id              String        @id @default(cuid())
  organizationId  String
  taskId          String
  task            ChecklistTask @relation(fields: [taskId], references: [id], onDelete: Cascade)
  areaId          String
  area            KitchenArea   @relation(fields: [areaId], references: [id], onDelete: Cascade)
  mondayActive    Boolean       @default(true)
  tuesdayActive   Boolean       @default(true)
  wednesdayActive Boolean       @default(true)
  thursdayActive  Boolean       @default(true)
  fridayActive    Boolean       @default(true)
  saturdayActive  Boolean       @default(true)
  sundayActive    Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@unique([taskId, areaId])
  @@index([organizationId, areaId])
  @@map("task_day_matrix")
  @@schema("public")
}

model TaskInstance {
  id                String           @id @default(cuid())
  organizationId    String
  date              DateTime         @db.Date
  weekday           Int
  importId          String?
  import            ShiftPlanImport? @relation(fields: [importId], references: [id], onDelete: SetNull)
  shiftAssignmentId String?
  shiftAssignment   ShiftAssignment? @relation(fields: [shiftAssignmentId], references: [id], onDelete: SetNull)
  userId            String
  user              UserProfile      @relation("TaskInstanceUser", fields: [userId], references: [id], onDelete: Cascade)
  areaId            String
  area              KitchenArea      @relation(fields: [areaId], references: [id])
  taskId            String
  task              ChecklistTask    @relation(fields: [taskId], references: [id], onDelete: Cascade)
  status            String           @default("open")
  completedAt       DateTime?
  completedByUserId String?
  completedBy       UserProfile?     @relation("TaskInstanceCompletedBy", fields: [completedByUserId], references: [id], onDelete: SetNull)
  verifiedAt        DateTime?
  verifiedByUserId  String?
  verifiedBy        UserProfile?     @relation("TaskInstanceVerifiedBy", fields: [verifiedByUserId], references: [id], onDelete: SetNull)
  dueAt             DateTime?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  taskIssues   TaskIssue[]
  taskComments TaskComment[]

  @@unique([shiftAssignmentId, taskId])
  @@index([organizationId, date, userId])
  @@index([organizationId, status, date])
  @@index([areaId, date])
  @@map("task_instances")
  @@schema("public")
}

model TaskIssue {
  id               String       @id @default(cuid())
  organizationId   String
  taskInstanceId   String
  taskInstance     TaskInstance @relation(fields: [taskInstanceId], references: [id], onDelete: Cascade)
  reportedByUserId String
  reportedBy       UserProfile  @relation("TaskIssueReportedBy", fields: [reportedByUserId], references: [id], onDelete: Cascade)
  title            String
  description      String?
  photoUrl         String?
  severity         String       @default("medium")
  status           String       @default("open")
  resolvedByUserId String?
  resolvedBy       UserProfile? @relation("TaskIssueResolvedBy", fields: [resolvedByUserId], references: [id], onDelete: SetNull)
  resolvedAt       DateTime?
  resolutionNotes  String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([organizationId, status])
  @@index([taskInstanceId])
  @@map("task_issues")
  @@schema("public")
}

model TaskComment {
  id              String       @id @default(cuid())
  taskInstanceId  String
  taskInstance    TaskInstance @relation(fields: [taskInstanceId], references: [id], onDelete: Cascade)
  createdByUserId String
  createdBy       UserProfile  @relation("TaskCommentCreatedBy", fields: [createdByUserId], references: [id], onDelete: Cascade)
  content         String
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([taskInstanceId])
  @@map("task_comments")
  @@schema("public")
}

model ShiftSignoff {
  id                 String      @id @default(cuid())
  organizationId     String
  date               DateTime    @db.Date
  weekday            Int
  workspaceGroupId   String
  department         String
  signedByUserId     String
  signedBy           UserProfile @relation("ShiftSignoffSignedBy", fields: [signedByUserId], references: [id], onDelete: Cascade)
  completedTaskCount Int
  totalTaskCount     Int
  openIssueCount     Int
  summary            String?
  notes              String?
  signedAt           DateTime    @default(now())

  @@unique([organizationId, date, workspaceGroupId, department])
