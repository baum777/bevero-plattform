  MOTORWORLD_INN_WEBSITE
  MANUAL_ENTRY
  EMAIL_IMPORT

  @@schema("public")
}

enum InquirySubject {
  BUSINESS_DINNER
  CORPORATE_EVENT
  INCENTIVE
  WEDDING
  PRIVATE_EVENT
  BIRTHDAY
  CONFERENCE
  SEMINAR
  WORKSHOP
