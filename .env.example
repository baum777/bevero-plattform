NODE_ENV="development"
PORT="4000"
DATABASE_URL="postgresql://postgres.your-project-ref:replace_me@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1&sslmode=require"
DIRECT_URL="postgresql://postgres:replace_me@db.your-project-ref.supabase.co:5432/postgres?sslmode=require"

# Required for DB target verification. Never set casually.
# Known owned development project: ienwshemokpsjwkedmyp (bevero-os / bevero-plattform).
# Foreign production project czinchfegtglmrloxlmh belongs to rauschenberger-os
# and is read-only/blocked from bevero-plattform by default.
BEVERO_DB_TARGET="local"
BEVERO_EXPECTED_SUPABASE_REF=""
BEVERO_ALLOW_PRODUCTION_MIGRATION=""
# Cross-project read-only override (for incident verification against rauschenberger-os projects).
# Do not uncomment by default. Read-only checks only; risk-bearing Prisma commands remain blocked.
# BEVERO_ALLOW_CROSS_PROJECT_READ="I_UNDERSTAND_THIS_IS_A_BEVERO_DEV_DB"

# Production requires a separate owner-approved gate. Do not uncomment by default:
# BEVERO_DB_TARGET="production"
# BEVERO_EXPECTED_SUPABASE_REF="czinchfegtglmrloxlmh"
# BEVERO_ALLOW_PRODUCTION_MIGRATION="I_UNDERSTAND_THIS_TOUCHES_PRODUCTION"
REDIS_URL="redis://localhost:6379"
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="replace_me"
NEXT_PUBLIC_API_BASE_URL="https://bevero-api.vercel.app"
NEXT_PUBLIC_SITE_URL="https://bevero-ui.vercel.app"
NEXT_PUBLIC_APP_ENV="local"
NEXT_PUBLIC_COMMIT_SHA=""

GASTRONOVI_API_BASE_URL=""
GASTRONOVI_API_KEY=""
GASTRONOVI_TENANT_ID=""
CORS_ALLOWED_ORIGINS=""
SUPABASE_JWT_SECRET="replace_me"
SMOKE_JWT_TOKEN=   # optional pre-signed JWT for smoke tests (no production service key); leave empty to auto-mint against SUPABASE_JWT_SECRET

SYNC_DEFAULT_LOOKBACK_DAYS="7"
SYNC_ENABLE_SCHEDULED_JOBS="false"
DEMO_MODE="false"
LOG_LEVEL="info"

# Procurement email ingest (FoodNotify via Microsoft Graph / Outlook)
# Organization the imported FoodNotify orders are attributed to (required for live ingest).
PROCUREMENT_ORGANIZATION_ID=""
# Microsoft Graph app-only credentials. Store real values only in deployment secrets or local .env.
MICROSOFT_TENANT_ID=""
MICROSOFT_CLIENT_ID=""
MICROSOFT_CLIENT_SECRET=""
FOODNOTIFY_MAILBOX=""
FOODNOTIFY_MAIL_FOLDER="Inbox"
FOODNOTIFY_IMPORTED_FOLDER="FoodNotify/Imported"
FOODNOTIFY_FAILED_FOLDER="FoodNotify/Failed"
FOODNOTIFY_IGNORED_FOLDER="FoodNotify/Ignored"
FOODNOTIFY_FROM_FILTER=""
FOODNOTIFY_IMPORT_MODE="graph"
FOODNOTIFY_IMPORT_ENABLED="false"
FOODNOTIFY_IMPORT_LOCK_TTL_SECONDS="300"
# Legacy IMAP placeholders remain accepted by env parsing but are not wired as the live adapter.
MAIL_IMAP_HOST=""
MAIL_IMAP_PORT="993"
MAIL_IMAP_USER=""
MAIL_IMAP_PASSWORD=""
MAIL_IMAP_POLL_INTERVAL="900000"
MAIL_IMAP_BACKOFF_MAX="1800000"
# Parser + anti-spoofing.
FOODNOTIFY_PARSE_CONFIDENCE_MIN="0.85"
FOODNOTIFY_PARSE_FAILURE_ALERT_THRESHOLD="0"
FOODNOTIFY_RAW_MAIL_MAX_BYTES="204800"
# Comma-separated trusted DKIM/sender domains used by the Phase-1 domain-check gate.
FOODNOTIFY_TRUSTED_SENDER_DOMAINS="foodnotify.com"
